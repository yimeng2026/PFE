import Mathlib.Data.Set.Basic

abbrev Language := Set (List Bool)

def ClassNP : Set Language :=
  { L | жѕГ?(verify : List Bool жѕФ?List Bool жѕФ?Bool),
    (жѕГРѓг x, x жѕГ?L жѕФ?жѕГ?(cert : List Bool), verify x cert = true) }

open Classical

lemma np_univ : ClassNP = Set.univ := by
  ext L
  simp [ClassNP]
  use (fun x _ => if x жѕГ?L then true else false)
  intro x
  constructor
  Уи» intro hx
    use []
    simp [hx]
  Уи» rintro жЅёРЋЪert, hcжЅё?    simp at hc
    exact hc
