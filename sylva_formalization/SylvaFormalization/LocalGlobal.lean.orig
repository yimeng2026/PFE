/-- Local-Global Principle 鏍稿績绫诲瀷绫?-/
class LocalGlobalPrinciple (L G : Type*) where
  localData : Type*
  compatibility : localData 鈫?Prop
  descent : 鈭€ (d : localData), compatibility d 鈫?G
  restriction : G 鈫?localData
  compatibility_restriction : 鈭€ g, compatibility (restriction g)
  descent_restriction : 鈭€ d hc, restriction (descent d hc) = d

/-! ============================================
    绗簩閮ㄥ垎锛氫笅闄嶆暟鎹殑褰㈠紡鍖?    ============================================ -/

structure DescentData (Idx : Type*) (LocalObj : Idx 鈫?Type*)
    (Transition : 鈭€ i j, LocalObj i 鈫?LocalObj j 鈫?Prop) where
  objects : 鈭€ i, LocalObj i
  isomorphisms : 鈭€ i j, Transition i j (objects i) (objects j)
  cocycle : 鈭€ i j k,
    Transition i k (objects i) (objects k) 鈫?    (Transition i j (objects i) (objects j) 鈭?     Transition j k (objects j) (objects k))

def EffectiveDescent {Idx : Type*} {LocalObj : Idx 鈫?Type*}
    {Transition : 鈭€ i j, LocalObj i 鈫?LocalObj j 鈫?Prop}
    (G : Type*)
    (toGlobal : DescentData Idx LocalObj Transition 鈫?G)
    (toDescent : G 鈫?DescentData Idx LocalObj Transition) : Prop :=
  鈭€ (d : DescentData Idx LocalObj Transition) (g : G),
    toGlobal (toDescent g) = g 鈭?toDescent (toGlobal d) = d

