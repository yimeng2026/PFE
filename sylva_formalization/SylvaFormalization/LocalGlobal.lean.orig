-- Hodge缁撴瀯绠€鍖栧畾涔?structure HodgeStructure (n : 鈩? where
  hodgeDecomp : 鈭€ (_p _q : 鈩?, _p + _q = n 鈫?Type

def HodgeClass (p : 鈩? (hs : HodgeStructure (2 * p : 鈩?) : Type :=
  hs.hodgeDecomp p p (by omega)

-- 浠ｆ暟闂摼瀹氫箟
inductive AlgebraicCycle (X : Type) [TopologicalSpace X] (k : 鈩? where
  | zero : AlgebraicCycle X k
  | subvariety (Z : Set X) (_closed : IsClosed Z) : AlgebraicCycle X k
  | add : AlgebraicCycle X k 鈫?AlgebraicCycle X k 鈫?AlgebraicCycle X k
  | smul : 鈩?鈫?AlgebraicCycle X k 鈫?AlgebraicCycle X k

-- 灞€閮ㄥ井鍒嗗舰寮?structure LocalDifferentialForms (X : Type) [TopologicalSpace X] where
  forms : 鈭€ (_p _q : 鈩?, X 鈫?鈩?  smooth : 鈭€ _p _q, Continuous (forms _p _q)

def LocalDifferentialForms.isHodgeClass {X : Type} [TopologicalSpace X]
    (_ldf : LocalDifferentialForms X) (_p : 鈩? : Prop := True

-- Hodge鍏ㄥ眬瀵硅薄
def HodgeGlobal (X : Type) [TopologicalSpace X] := 危 (k : 鈩?, AlgebraicCycle X k

