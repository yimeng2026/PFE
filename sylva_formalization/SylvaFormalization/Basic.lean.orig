import Mathlib

namespace Sylva

/-- GF(3) - The Galois Field with 3 elements -/
abbrev GF3 := Fin 3

/-- Golden Ratio -/
noncomputable def phi : Real := (1 + Real.sqrt 5) / 2

/-- Lambda(5/2) - The 5/2 scaling constant -/
noncomputable def lambda_5_2 : Real := 5 / 2

end Sylva
